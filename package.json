{
  "name": "@kitsunekode/sweep",
  "version": "0.1.0",
  "description": "Safe, fast artifact cleanup CLI for any project tree",
  "keywords": [
    "artifacts",
    "build",
    "cleanup",
    "cli",
    "devtools",
    "monorepo",
    "node_modules"
  ],
  "homepage": "https://github.com/KitsuneKode/sweep#readme",
  "bugs": {
    "url": "https://github.com/KitsuneKode/sweep/issues"
  },
  "license": "MIT",
  "author": "KitsuneKode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KitsuneKode/sweep.git"
  },
  "bin": {
    "sweep": "./dist/sweep.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/sweep.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "clean": "rm -rf dist",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "fmt": "oxfmt src tests scripts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "preflight": "bun run scripts/preflight.ts",
    "pack:preview": "npm pack --dry-run",
    "pack": "npm pack",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run prepublishOnly && changeset publish",
    "prepare": "husky || true",
    "prepublishOnly": "bun run typecheck && bun run lint && bun run test && bun run build && bun run preflight"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^22.0.0",
    "bun-types": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "oxfmt": "^0.45.0",
    "oxlint": "^0.13.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
